# 🪷 OpenClaw Workspace .gitignore
# REVIEW-FIX: W2 — Tạo .gitignore tổng để tránh commit nhầm file không cần thiết

# ── Node.js ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg
.eggs/
venv/
.venv/
env/
.env
pip-log.txt
pip-delete-this-directory.txt
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ── Databases ──
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ── Docker ──
.docker/

# ── Ứng dụng ──
*.log
*.pid
*.seed
*.pid.lock

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-workspace
*.sublime-project

# ── Environment & Secrets ──
.env.local
.env.*.local
*.pem
*.key
credentials*.json
service-account*.json
secrets.yaml
secrets.yml

# ── OS files ──
.directory
Desktop.ini
$RECYCLE.BIN/

# ── Build output ──
dist/
build/
out/
.next/
.nuxt/
.output/
public/build/

# ── Coverage ──
coverage/
.nyc_output/
*.lcov

# ── Temp ──
tmp/
temp/
*.tmp
*.bak
*.backup
.cache/

# ── Large binary files ──
*.zip
*.tar.gz
*.7z
*.rar
*.mp4
*.mp3
*.wav
*.mov
*.avi
*.exe
*.dll

# ── Agent-specific ──
.agent-cache/
.agent-state/
